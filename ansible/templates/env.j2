# Generated by Ansible — {{ ansible_date_time.iso8601 }} — env={{ env_name }}
# Source: ansible/templates/env.j2
# Do not edit manually — use ansible-playbook -i inventory.ini playbook.yml -e env_name=<env>

# Service versions
OTEL_SERVICE_NAME=gateway
OTEL_SERVICE_VERSION=0.1.0

# OTLP exporter endpoint (Alloy)
OTEL_EXPORTER_OTLP_ENDPOINT={{ environments[env_name].otel_endpoint }}

# Service URLs
ORDERS_URL=http://orders:8000
PAYMENTS_URL=http://payments:8000

# HTTP timeout
HTTP_TIMEOUT=5.0

# Environment label — used for Loki label deployment_environment and OTel resource
ENVIRONMENT={{ environments[env_name].environment_label }}

# Grafana
GRAFANA_USER={{ grafana_user }}
GRAFANA_PASSWORD={{ grafana_password }}

# Mimir
MIMIR_INGESTION_RATE={{ environments[env_name].mimir_ingestion_rate }}

# Loki
LOKI_RETENTION={{ environments[env_name].loki_retention }}

# Tempo
TEMPO_RETENTION={{ environments[env_name].tempo_retention }}

# Docker image tags (pinned from group_vars)
GRAFANA_VERSION={{ grafana_version }}
ALLOY_VERSION={{ alloy_version }}
MIMIR_VERSION={{ mimir_version }}
LOKI_VERSION={{ loki_version }}
TEMPO_VERSION={{ tempo_version }}
PROMETHEUS_VERSION=latest
ALERTMANAGER_VERSION=latest

# Python
PYTHON_VERSION=3.12-slim
