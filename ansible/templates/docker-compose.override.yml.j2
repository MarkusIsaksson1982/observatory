# Generated by Ansible — env={{ env_name }}
# Optional override — demonstrates second template without overwriting main compose file
# Usage: docker compose --env-file .env up -d
# This file is intentionally minimal — portfolio signal over complexity

services:
  gateway:
    environment:
      - ENVIRONMENT={{ environments[env_name].environment_label }}
      - OTEL_EXPORTER_OTLP_ENDPOINT={{ environments[env_name].otel_endpoint }}
