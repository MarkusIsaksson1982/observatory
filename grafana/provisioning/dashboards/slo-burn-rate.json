{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus/Mimir",
      "description": "Mimir or Prometheus datasource for Sloth recording rules",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "VARIABLE_SLO",
      "label": "SLO",
      "description": "Select which SLO group to visualize",
      "type": "query",
      "query": "label_values(slo:sli_error:ratio_rate5m, slo)"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "table", "name": "Table" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Firing Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Google SRE-style SLO burn rate and error budget dashboard — Sloth recording rules",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "SLO Objectives",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "yellow","value": 99.0 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "title": "Availability",
      "description": "Current availability = 100 × (1 - error ratio)",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * (1 - slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"}) or vector(100)",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "yellow","value": 50 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Error Budget Remaining",
      "description": "Remaining error budget = 100 × (1 - burn_rate) × SLO target",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * (1 - slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"})",
          "legendFormat": "Budget %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow","value": 1 },
              { "color": "orange","value": 6 },
              { "color": "red",   "value": 14.4 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Current Burn Rate",
      "description": ">1 = burning error budget too fast. >14.4x = will exhaust in <1 hour (SLO violation imminent)",
      "type": "stat",
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"}",
          "legendFormat": "Burn Rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "yellow","value": 5 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "title": "SLI (Error %)",
      "description": "Current error ratio × 100",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"}",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "Burn Rate (Window Comparison)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "dashed+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red",    "value": 14.4 }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Burn Rate — Fast Window (5m)",
      "description": "Short burn rate window. SLO at risk when this exceeds 1.0 for sustained periods",
      "type": "timeseries",
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"}",
          "legendFormat": "5m burn rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "dashed+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red",    "value": 14.4 }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Burn Rate — Slow Window (30m)",
      "description": "Longer burn rate window. Alerts fire when both fast and slow windows breach thresholds simultaneously",
      "type": "timeseries",
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"30m\"}",
          "legendFormat": "30m burn rate",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Error Budget Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "green",  "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Budget Consumed" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 50 },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "min"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Error Budget Remaining vs Consumed",
      "description": "Remaining = green area. Consumed = red/pink overlay. Threshold at 99% remaining = 1% consumed",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 * (1 - slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"})",
          "legendFormat": "Remaining",
          "refId": "A"
        },
        {
          "expr": "100 * slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"}",
          "legendFormat": "Budget Consumed",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "SLI — Multi-Window Trend",
      "description": "Error ratio across multiple time windows. Longer windows smooth short spikes",
      "type": "timeseries",
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"5m\"}",
          "legendFormat": "5m SLI",
          "refId": "A"
        },
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"30m\"}",
          "legendFormat": "30m SLI",
          "refId": "B"
        },
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"1h\"}",
          "legendFormat": "1h SLI",
          "refId": "C"
        },
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=\"${VAR_SLO}\", sloth_window=\"6h\"}",
          "legendFormat": "6h SLI",
          "refId": "D"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 103,
      "title": "SLO Inventory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "filterable": true },
          "thresholds": { "mode": "absolute", "steps": [] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "0": { "color": "green", "text": "HEALTHY" } }, "type": "value" },
                  { "options": { "1": { "color": "red", "text": "BREACHING" } }, "type": "value" }
                ]
              },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Burn Rate" },
            "properties": [
              { "id": "unit", "value": "short" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "orange", "value": 6 },
                    { "color": "red",    "value": 14.4 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 23 },
      "id": 9,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "title": "SLO Inventory",
      "description": "All monitored SLOs with current burn rate and breach status",
      "type": "table",
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_window=\"5m\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": {
              "sloth_service": "SLO Name",
              "slo": "SLO Target",
              "window": "Window",
              "Value #A": "Burn Rate"
            }
          }
        },
        {
          "id": "calculate",
          "options": {
            "mode": "index",
            "expressions": ["Burn Rate > 1.0"],
            "newFields": ["Status"]
          }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "tags": ["slo", "sloth", "sre", "burn-rate"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "gateway", "value": "gateway" },
        "definition": "label_values(slo:current_burn_rate:ratio, sloth_service)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "VAR_SLO",
        "label": "SLO Service",
        "options": [],
        "query": { "query": "label_values(slo:current_burn_rate:ratio, sloth_service)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "SLO Burn Rate",
  "uid": "slo-burn-rate",
  "version": 1
}
