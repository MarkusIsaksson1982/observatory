# Environment variables for Observatory
# Copy to .env and adjust as needed

# Service versions
OTEL_SERVICE_NAME=gateway
OTEL_SERVICE_VERSION=0.1.0

# OTLP exporter endpoint (Alloy)
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317

# Service URLs
ORDERS_URL=http://orders:8000
PAYMENTS_URL=http://payments:8000

# HTTP timeout
HTTP_TIMEOUT=5.0

# Environment
ENVIRONMENT=local

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Mimir
MIMIR_INGESTION_RATE=10000

# Loki
LOKI_RETENTION=30d

# Tempo
TEMPO_RETENTION=1h

# Docker image tags (update before release)
GRAFANA_VERSION=11.1.0
ALLOY_VERSION=v1.5.0
MIMIR_VERSION=2.12.0
LOKI_VERSION=3.1.0
TEMPO_VERSION=2.5.0
PROMETHEUS_VERSION=latest
ALERTMANAGER_VERSION=latest

# Python
PYTHON_VERSION=3.12-slim