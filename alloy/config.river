// Alloy Configuration for Observatory
// OTLP logs → Loki, OTLP traces → Tempo (RED metrics via Tempo metrics-generator)
//
// Pipeline:
//   Logs:   OTLP Receiver → Attributes Processor (label hints) → OTLP/HTTP → Loki
//   Traces: OTLP Receiver → OTLP Exporter → Tempo
//
// Label naming note: Loki's OTLP ingestion sanitizes resource attributes
// to Prometheus label format — dots become underscores. So service.name → service_name.
// Acceptance criteria: {service_name="gateway"}.
//
// Structured metadata fix (Claude Sonnet 5, 2026-07-20): otelcol.exporter.loki
// wraps all OTLP attributes into a JSON body blob, losing structured metadata
// (trace_id, span_id, etc.) — Alloy #2757. Switched to otelcol.exporter.otlphttp
// which sends native OTLP/HTTP, preserving structured metadata in Loki 3.x.
// Loki's allow_structured_metadata: true (loki.yml) enables queryable trace
// correlation: {service_name="gateway"} | trace_id != "".

// ============================================================
// LOGS: OTLP Receiver → Processor (label hints) → OTLP/HTTP → Loki
// ============================================================

otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }
  output {
    logs   = [otelcol.processor.attributes.loki_hints.input]
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.processor.attributes "loki_hints" {
  // Inserts loki.resource.labels hint so otelcol.exporter.loki promotes
  // resource attributes to Loki stream labels (service.name → service_name).
  //
  // NOTE: This hint is only consumed by otelcol.exporter.loki.
  // After switching to otelcol.exporter.otlphttp (2026-07-20), Loki's own
  // OTLP ingestion handles attribute-to-label mapping natively. The processor
  // is retained for backward compatibility and in case we revert.
  action {
    key    = "loki.resource.labels"
    action = "insert"
    value  = "service.name,deployment.environment"
  }
  output {
    logs = [otelcol.exporter.otlphttp.loki.input]
  }
}

// otelcol.exporter.otlphttp replaces otelcol.exporter.loki (2026-07-20).
// otelcol.exporter.loki wraps everything into a JSON body blob and does not
// support structured metadata (Alloy #2757). otelcol.exporter.otlphttp
// sends native OTLP/HTTP, preserving trace_id/span_id as queryable
// structured metadata in Loki 3.x.
otelcol.exporter.otlphttp "loki" {
  client {
    // otelcol.exporter.otlphttp appends /v1/logs automatically.
    // Final URL: http://loki:3100/otlp/v1/logs
    endpoint = "http://loki:3100/otlp"
  }
}

// ============================================================
// TRACES → Tempo: OTLP Exporter
// ============================================================

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"
    tls {
      insecure = true
    }
  }
}

// ============================================================
// SCRAPING: Prometheus scrape for infra self-monitoring
// Alloy + Loki /metrics endpoints forwarded to Mimir.
// ============================================================

prometheus.scrape "alloy" {
  targets      = [{"__address__" = "alloy:12345"}]
  job_name     = "alloy"
  metrics_path = "/metrics"
  forward_to   = [prometheus.remote_write.mimir.receiver]
}

prometheus.scrape "loki" {
  targets      = [{"__address__" = "loki:3100"}]
  job_name     = "loki"
  metrics_path = "/metrics"
  forward_to   = [prometheus.remote_write.mimir.receiver]
}

// ============================================================
// METRICS PIPELINE: Scraped infra metrics → Mimir
// ============================================================

prometheus.remote_write "mimir" {
  endpoint {
    url = "http://mimir:9009/api/v1/push"
  }
}
